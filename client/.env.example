# Copy to .env.local (gitignored) to configure the API layer locally.

# Prefix for backend requests. Leave unset to use the Vite dev proxy
# (see vite.config.ts, which forwards /api to http://localhost:8000).
# VITE_API_BASE_URL=

# Set to "false" to call the real backend instead of using mock data.
# VITE_USE_MOCK_DATA=false
